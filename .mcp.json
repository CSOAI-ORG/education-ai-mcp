{
  "name": "education-ai-mcp",
  "description": "> **By [MEOK AI Labs](https://meok.ai)** \u2014 Sovereign AI tools for everyone.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "generate_lesson_plan",
      "description": "Generate a structured lesson plan with objectives, activities, and assessment.",
      "parameters": {
        "type": "object",
        "properties": {
          "subject": {
            "type": "string"
          },
          "topic": {
            "type": "string"
          },
          "age_group": {
            "type": "string"
          },
          "duration_minutes": {
            "type": "integer"
          },
          "learning_objectives": {
            "type": "array"
          },
          "differentiation": {
            "type": "boolean"
          }
        },
        "required": [
          "subject",
          "topic"
        ]
      }
    },
    {
      "name": "create_quiz",
      "description": "Create a quiz with various question types aligned to Bloom's taxonomy.",
      "parameters": {
        "type": "object",
        "properties": {
          "topic": {
            "type": "string"
          },
          "num_questions": {
            "type": "integer"
          },
          "difficulty": {
            "type": "string"
          },
          "question_types": {
            "type": "array"
          },
          "age_group": {
            "type": "string"
          },
          "include_answers": {
            "type": "boolean"
          }
        },
        "required": [
          "topic"
        ]
      }
    },
    {
      "name": "analyze_student_progress",
      "description": "Analyze student performance trends and generate progress report.",
      "parameters": {
        "type": "object",
        "properties": {
          "student_name": {
            "type": "string"
          },
          "assessments": {
            "type": "array"
          },
          "target_grade": {
            "type": "number"
          }
        },
        "required": [
          "student_name",
          "assessments"
        ]
      }
    },
    {
      "name": "recommend_learning_path",
      "description": "Recommend a personalized learning path based on student profile.",
      "parameters": {
        "type": "object",
        "properties": {
          "subject": {
            "type": "string"
          },
          "current_level": {
            "type": "string"
          },
          "learning_style": {
            "type": "string"
          },
          "goals": {
            "type": "array"
          },
          "available_hours_per_week": {
            "type": "integer"
          }
        },
        "required": [
          "subject"
        ]
      }
    },
    {
      "name": "generate_rubric",
      "description": "Generate an assessment rubric with detailed criteria and descriptors.",
      "parameters": {
        "type": "object",
        "properties": {
          "assignment_title": {
            "type": "string"
          },
          "criteria": {
            "type": "array"
          },
          "levels": {
            "type": "integer"
          },
          "max_score": {
            "type": "integer"
          },
          "assignment_type": {
            "type": "string"
          }
        },
        "required": [
          "assignment_title"
        ]
      }
    }
  ]
}